          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('ticketId', res.id);",
                  "    console.log('✅ Ticket booked!');",
                  "    console.log('🎟️ Reference Code:', res.referenceCode);",
                  "    console.log('💺 Seat:', res.seatCode);",
                  "    console.log('💰 Price:', res.pricePaid);",
                  "}",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has referenceCode', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('referenceCode');",
                  "});",
                  "pm.test('Has qrCode', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('qrCodeBase64');",
                  "});"
                ],
                "type": "text/javascript"
